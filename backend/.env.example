# ============================================================
# Fluidity - Configuration du Backend (exemple)
# Copier en .env et renseigner les valeurs réelles
# ============================================================

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017/fluidity

# --- JWT ---
JWT_SECRET=changez_ce_secret_en_production_aleatoire
JWT_EXPIRES_IN=7d

# --- Serveur ---
PORT=3000

# --- SMTP (Nodemailer) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@company.com
SMTP_PASS=mot_de_passe_email
MAIL_FROM=Fluidity <notifications@company.com>

# --- URLs ---
FRONTEND_URL=http://localhost:4200
